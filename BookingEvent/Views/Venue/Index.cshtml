@model IEnumerable<BookingEvent.Models.Venue>

@{
    ViewData["Title"] = "Venues";
}

<div class="container mt-5">

    <div class="d-flex justify-content-between mb-4">

        <h1 class="fw-bold">Venues</h1>

        <a asp-action="Create" class="btn btn-success">
            Add Venue
        </a>

    </div>

    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">

                <div class="card shadow-lg border-0 rounded-4 h-100">

                    <img src="@item.ImageUrl"
                         class="card-img-top"
                         style="height:250px; object-fit:cover;" />

                    <div class="card-body">

                        <h4 class="fw-bold">@item.VenueName</h4>

                        <p><strong>Location:</strong> @item.VenueLocation</p>

                        <p><strong>Capacity:</strong> @item.VenueCapacity</p>

                    </div>

                    <!-- ACTION BUTTONS -->
                    <div class="card-footer bg-white border-0">

                        <div class="d-flex gap-2">

                            <!-- Details -->
                            <a asp-action="Details"
                                   asp-route-id="@item.VenueId"
                                   class="btn btn-primary btn-sm w-100">
                                Details
                            </a>

                            <!-- Edit -->
                            <a asp-action="Edit"
                                   asp-route-id="@item.VenueId"
                                   class="btn btn-warning btn-sm w-100">
                                Edit
                            </a>

                            <!-- Delete -->
                            <a asp-action="Delete"
                                   asp-route-id="@item.VenueId"
                                   class="btn btn-danger btn-sm w-100">
                                Delete
                            </a>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

</div>