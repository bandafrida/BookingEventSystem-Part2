@model BookingEvent.Models.Booking

@{
    ViewData["Title"] = "Create Booking";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header bg-dark text-white">
                    <h3 class="mb-0">Create Booking</h3>
                </div>

                <div class="card-body p-4">

                    <form asp-action="Create" method="post">

                        <div asp-validation-summary="All" class="alert alert-danger"></div>
                        <div class="mb-3">
                            <label asp-for="BookingDate" class="form-label fw-bold"></label>
                            <input asp-for="BookingDate" type="datetime-local" class="form-control" />
                            <span asp-validation-for="BookingDate" class="text-danger"></span>
                        </div>


                        <div class="mb-3">
                            <label asp-for="VenueId" class="form-label fw-bold"></label>

                            <select asp-for="VenueId"
                                    class="form-select"
                                    asp-items="ViewBag.VenueId">

                                <option value="">-- Select Venue --</option>
                            </select>

                            <span asp-validation-for="VenueId" class="text-danger"></span>
                        </div>


                        <div class="mb-3">
                            <label asp-for="EventId" class="form-label fw-bold"></label>

                            <select asp-for="EventId"
                                    class="form-select"
                                    asp-items="ViewBag.EventId">\
                                <option value="">-- Select Event --</option>
                            </select>

                            <span asp-validation-for="EventId" class="text-danger"></span>
                        </div>


                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-success w-100">
                                Create Booking
                            </button>

                            <a asp-action="Index" class="btn btn-secondary w-100">
                                Back
                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}