@model BookingEvent.Models.Booking

@{
    ViewData["Title"] = "Edit Booking";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header bg-warning text-dark">
                    <h3>Edit Booking</h3>
                </div>

                <div class="card-body">

                    <form asp-action="Edit">

                        <input type="hidden"
                               asp-for="BookingId" />

                        <div asp-validation-summary="All"
                             class="alert alert-danger">
                        </div>

                        <!-- Booking Date -->
                        <div class="mb-3">

                            <label asp-for="BookingDate"
                                   class="form-label fw-bold">
                            </label>

                            <input asp-for="BookingDate"
                                   type="datetime-local"
                                   class="form-control" />

                        </div>

                        <!-- Event -->
                        <div class="mb-3">

                            <label asp-for="EventId"
                                   class="form-label fw-bold">
                            </label>

                            <select asp-for="EventId"
                                    class="form-select"
                                    asp-items="ViewBag.EventId">
                            </select>

                        </div>

                        <!-- Venue -->
                        <div class="mb-3">

                            <label asp-for="VenueId"
                                   class="form-label fw-bold">
                            </label>

                            <select asp-for="VenueId"
                                    class="form-select"
                                    asp-items="ViewBag.VenueId">
                            </select>

                        </div>

                        <div class="d-flex gap-2">

                            <button type="submit"
                                    class="btn btn-success w-100">
                                Save Changes
                            </button>

                            <a asp-action="Index"
                                   class="btn btn-secondary w-100">
                                Back
                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}