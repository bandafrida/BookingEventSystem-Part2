@model IEnumerable<BookingEvent.Models.Event>

@{
    ViewData["Title"] = "Events";
}

<div class="container mt-5">

    <!-- ERROR ALERT -->
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show"
             role="alert">

            @TempData["Error"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>

        </div>
    }

    <!-- PAGE HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <h1 class="fw-bold text-dark">Events</h1>

        <a asp-action="Create"
               class="btn btn-success shadow-sm">
            + Create Event
        </a>

    </div>

    <!-- EVENT CARDS -->
    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">

                <div class="card shadow-lg border-0 rounded-4 h-100">

                    <!-- EVENT IMAGE -->
                    <img src="@item.ImageUrl"
                         class="card-img-top"
                         style="height:250px; object-fit:cover;"
                         onerror="this.src='/images/wall.jpg';" />

                    <!-- CARD BODY -->
                    <div class="card-body">

                        <h4 class="fw-bold text-primary">
                            @item.EventName
                        </h4>

                        <p class="mb-2">
                            <strong>Date:</strong>
                            @item.EventDate.ToString("dd MMM yyyy")
                        </p>

                        <p>
                            <strong>Time:</strong>
                            @item.EventTime.ToString("HH:mm")
                        </p>

                    </div>

                    <!-- CARD FOOTER -->
                    <div class="card-footer bg-white border-0">

                        <div class="d-flex gap-2">

                            <!-- DETAILS -->
                            <a asp-action="Details"
                                   asp-route-id="@item.EventId"
                                   class="btn btn-primary btn-sm w-100">
                                Details
                            </a>

                            <!-- EDIT -->
                            <a asp-action="Edit"
                                   asp-route-id="@item.EventId"
                                   class="btn btn-warning btn-sm w-100 text-white">
                                Edit
                            </a>

                            <!-- DELETE -->
                            <a asp-action="Delete"
                                   asp-route-id="@item.EventId"
                                   class="btn btn-danger btn-sm w-100">
                                Delete
                            </a>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

</div>